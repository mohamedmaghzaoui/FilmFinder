// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}
enum AnimeStatus {
  ongoing
  finished
}
model Movie {
  id          String @id @default(cuid())
  title       String
  genre       String
  duration    Int
  rating      Float
  releaseYear Int
  description String
}
model Series {
  id          String @id @default(cuid())
  title       String
  genre       String
  seasons     Int
  episodes    Int
  rating      Float
  releaseYear Int
  description String
}
model Anime {
  id          String @id @default(cuid())
  title       String
  genre       String
  episodes    Int
  rating      Float
  releaseYear Int
  status      AnimeStatus // "ongoing" | "finished"
  description String
}
